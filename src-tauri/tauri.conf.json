{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Axis",
  "version": "0.1.5",
  "identifier": "com.gabrielleall.axis-desktop",
  "build": {
    "removeUnusedCommands": true,
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Axis",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "decorations": true,
        "alwaysOnTop": false,
        "transparent": false,
        "shadow": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' tauri: ipc: http://ipc.localhost"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "createUpdaterArtifacts": true,
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Gabriel Leall",
    "category": "DeveloperTool",
    "shortDescription": "Axis application",
    "longDescription": "Axis application built with Tauri and React.",
    "copyright": "Copyright © 2026 Gabriel Leall. All rights reserved.",
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "startMenuFolder": "Axis"
      }
    },
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "providerShortName": null,
      "entitlements": null,
      "exceptionDomain": ""
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Gabriel-Leall/axis-desktop/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZCRDc2RkFDODExMDYwNApSV1FFQmhISStuYTlEN0pERFVIYUpVRDhBNEE4bFpPemJhZGZhdVJMNWkzSlBEL0VneGY1N0ZRVwo="
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["axis"]
      }
    }
  }
}
